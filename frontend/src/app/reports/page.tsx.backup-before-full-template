function DistributionList({ rows, total }: { rows: DistributionRow[]; total: number }) {
  const filteredRows = rows.filter((row) => row.count > 0);
  const radius = 42;
  const stroke = 12;
  const circumference = 2 * Math.PI * radius;

  const palette = ["#22d3ee", "#ef4444", "#f59e0b", "#10b981", "#818cf8", "#a855f7", "#94a3b8"];

  let offset = 0;
  const segments = filteredRows.map((row, index) => {
    const percent = total > 0 ? row.count / total : 0;
    const dash = percent * circumference;
    const segment = {
      ...row,
      color: palette[index % palette.length],
      dash,
      offset,
      percent: Math.round(percent * 100),
    };
    offset += dash;
    return segment;
  });

  if (filteredRows.length === 0) {
    return <EmptyText>No distribution data available.</EmptyText>;
  }

  return (
    <div className="grid gap-5 xl:grid-cols-[190px_1fr]">
      <div className="flex flex-col items-center justify-center rounded-3xl border border-white/10 bg-black/25 p-5">
        <div className="relative h-[160px] w-[160px]">
          <svg viewBox="0 0 120 120" className="h-full w-full -rotate-90">
            <circle cx="60" cy="60" r={radius} fill="transparent" stroke="rgba(255,255,255,0.07)" strokeWidth={stroke} />

            {segments.map((segment) => (
              <circle
                key={segment.label}
                cx="60"
                cy="60"
                r={radius}
                fill="transparent"
                stroke={segment.color}
                strokeWidth={stroke}
                strokeLinecap="round"
                strokeDasharray={`${segment.dash} ${circumference - segment.dash}`}
                strokeDashoffset={-segment.offset}
              />
            ))}
          </svg>

          <div className="absolute inset-0 flex flex-col items-center justify-center text-center">
            <span className="text-4xl font-light text-white">{total}</span>
            <span className="mt-1 text-[10px] font-black uppercase tracking-[0.18em] text-gray-500">
              Total
            </span>
          </div>
        </div>

        <p className="mt-4 text-center text-xs leading-5 text-gray-500">
          Campaign distribution summary.
        </p>
      </div>

      <div className="space-y-3">
        {segments.map((row, index) => (
          <div key={row.label} className="rounded-3xl border border-white/10 bg-black/25 p-4">
            <div className="mb-3 flex items-center justify-between gap-5">
              <div className="flex min-w-0 items-center gap-3">
                <span
                  className="h-3 w-3 shrink-0 rounded-full shadow-[0_0_14px_currentColor]"
                  style={{ backgroundColor: row.color, color: row.color }}
                />
                <div className="min-w-0">
                  <p className="truncate text-[11px] font-black uppercase tracking-[0.18em] text-gray-200">
                    {row.label}
                  </p>
                  <p className="mt-1 text-[11px] text-gray-500">
                    Rank #{index + 1} in this distribution
                  </p>
                </div>
              </div>

              <div className="text-right">
                <p className="text-lg font-light text-white">{row.count}</p>
                <p className="text-[10px] font-black uppercase tracking-[0.14em] text-gray-500">
                  {row.percent}%
                </p>
              </div>
            </div>

            <div className="h-2.5 overflow-hidden rounded-full bg-black/70">
              <div
                className="h-full rounded-full"
                style={{
                  width: `${row.percent}%`,
                  backgroundColor: row.color,
                  boxShadow: `0 0 18px ${row.color}55`,
                }}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}


