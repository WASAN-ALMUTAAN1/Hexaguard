function RiskMatrix({ results }: { results: NormalizedResult[] }) {
  const levels: RiskLevel[] = ["Critical", "High", "Medium", "Low", "Safe", "Not Available"];

  const counts = levels.flatMap((inputLevel) =>
    levels.map((outputLevel) =>
      results.filter((item) => item.inputRiskLevel === inputLevel && item.outputRiskLevel === outputLevel).length
    )
  );

  const maxCount = Math.max(1, ...counts);

  function cellColor(level: RiskLevel, count: number) {
    if (count === 0) return "rgba(255,255,255,0.025)";
    const alpha = Math.min(0.82, 0.18 + (count / maxCount) * 0.52);

    if (level === "Critical") return `rgba(244,63,94,${alpha})`;
    if (level === "High") return `rgba(249,115,22,${alpha})`;
    if (level === "Medium") return `rgba(245,158,11,${alpha})`;
    if (level === "Low") return `rgba(59,130,246,${alpha})`;
    if (level === "Safe") return `rgba(16,185,129,${alpha})`;

    return `rgba(148,163,184,${alpha})`;
  }

  function cellText(level: RiskLevel, count: number) {
    if (count === 0) return "text-gray-600";
    if (level === "Safe") return "text-emerald-100";
    if (level === "Low") return "text-blue-100";
    if (level === "Medium") return "text-amber-100";
    if (level === "High") return "text-orange-100";
    if (level === "Critical") return "text-red-100";
    return "text-gray-100";
  }

  return (
    <div className="space-y-4">
      <div className="grid gap-4 sm:grid-cols-3">
        <div className="rounded-3xl border border-white/10 bg-black/25 p-4">
          <p className="text-[10px] font-black uppercase tracking-[0.16em] text-gray-500">Matrix Purpose</p>
          <p className="mt-2 text-sm leading-6 text-gray-300">
            Compares input threat severity against model output residual risk.
          </p>
        </div>

        <div className="rounded-3xl border border-white/10 bg-black/25 p-4">
          <p className="text-[10px] font-black uppercase tracking-[0.16em] text-gray-500">High Priority Cells</p>
          <p className="mt-2 text-sm leading-6 text-gray-300">
            Medium, High, or Critical output risk requires review.
          </p>
        </div>

        <div className="rounded-3xl border border-white/10 bg-black/25 p-4">
          <p className="text-[10px] font-black uppercase tracking-[0.16em] text-gray-500">Total Findings</p>
          <p className="mt-2 text-3xl font-light text-white">{results.length}</p>
        </div>
      </div>

      <div className="overflow-auto rounded-3xl border border-white/10 bg-black/20">
        <table className="w-full min-w-[820px] border-separate border-spacing-0 text-center text-sm">
          <thead>
            <tr className="bg-black/45 text-[10px] uppercase tracking-widest text-gray-500">
              <th className="sticky left-0 z-10 bg-black/80 px-4 py-4 text-left font-semibold">
                Input \ Output
              </th>

              {levels.map((level) => (
                <th key={level} className="px-4 py-4 font-semibold">
                  {level}
                </th>
              ))}
            </tr>
          </thead>

          <tbody>
            {levels.map((inputLevel) => (
              <tr key={inputLevel}>
                <td className="sticky left-0 z-10 border-t border-white/5 bg-black/80 px-4 py-4 text-left font-medium text-gray-300">
                  {inputLevel}
                </td>

                {levels.map((outputLevel) => {
                  const count = results.filter(
                    (item) => item.inputRiskLevel === inputLevel && item.outputRiskLevel === outputLevel
                  ).length;

                  return (
                    <td key={outputLevel} className="border-t border-white/5 p-2">
                      <div
                        className="flex h-14 flex-col items-center justify-center rounded-2xl border border-white/10 transition hover:scale-[1.03] hover:border-cyan-400/40 hover:shadow-[0_0_18px_rgba(34,211,238,0.12)]"
                        style={{ backgroundColor: cellColor(outputLevel, count) }}
                        title={`${inputLevel} input → ${outputLevel} output: ${count}`}
                      >
                        <span className={`text-lg font-semibold ${cellText(outputLevel, count)}`}>
                          {count > 0 ? count : "—"}
                        </span>

                        {count > 0 ? (
                          <span className="mt-1 text-[9px] uppercase tracking-[0.12em] text-white/60">
                            finding{count > 1 ? "s" : ""}
                          </span>
                        ) : null}
                      </div>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}


